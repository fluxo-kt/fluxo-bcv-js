#!/bin/sh

# SC2086: Double quote to prevent globbing and word splitting.
# shellcheck disable=SC2086

./gradlew --stop --info

COMMON_TASKS="apiDump dependencyGuardBaseline --continue -Dlint.baselines.continue=true"
export GRADLE_OPTS="${GRADLE_OPTS} -Dorg.gradle.logging.stacktrace=all"
export GRADLE_OPTS="${GRADLE_OPTS} -Dorg.gradle.caching=false -Dkotlin.incremental=false"
export CI=true
export RELEASE=true
EXIT_CODE=0

echo ""
echo "===================================="
echo "======== RUN BASELINE TASKS ========"
echo "===================================="

# Force re-run for all the tasks
# -U: Refresh dependencies
#COMMON_TASKS="${COMMON_TASKS} --rerun-tasks -U"

./gradlew ${COMMON_TASKS} detektBaselineMerge updateLintBaseline || EXIT_CODE=101

echo ""
echo "=======> checks/latest"
cd checks/latest || exit 102
pwd
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=103

echo ""
echo "=======> checks/middle"
cd ../middle || exit 107
pwd
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=108

echo ""
echo "=======> checks/kgp-only"
cd ../kgp-only || exit 109
pwd
# Embedded-only path. Also refresh KGP's KLIB ABI baseline via
# updateKotlinAbi — distinct from this plugin's apiDump.
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock updateKotlinAbi || EXIT_CODE=110

echo ""
echo "=======> checks/dual"
cd ../dual || exit 111
pwd
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=112

echo ""
echo "=======> checks/js-only"
cd ../js-only || exit 104
pwd
# js-only uses the legacy `kotlin("js")` plugin (not KMP) but still
# materialises `kotlin-js-store/yarn.lock`. Without this refresh the
# lock silently rots on every Kotlin bump, surfacing later as a
# `Lock file was changed. Run the kotlinUpgradeYarnLock task` failure
# on the next CI run after a baseline regen.
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=105


# Go back to root
cd ../../ || exit 106

if [ ${EXIT_CODE} -ne 0 ]; then
  echo ""
  echo "================================"
  echo "== BASELINE TASKS FAILED: ${EXIT_CODE} =="
  echo "================================"
  exit ${EXIT_CODE}
fi
