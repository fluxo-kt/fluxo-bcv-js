#!/bin/sh

# SC2086: Double quote to prevent globbing and word splitting.
# shellcheck disable=SC2086

./gradlew --stop --info

# `apiDump` exists in every cell (root via BCV; checks/* via this plugin
# or KGP-embedded). `dependencyGuardBaseline` only exists where the
# `dependency-guard` plugin is applied — currently the root plugin
# module, `checks/latest`, and `checks/js-only` (NOT in `middle`,
# `kgp-only`, `dual`). Including it in COMMON would fail task selection
# in those three. Keep COMMON minimal; layer cell-specific tasks per
# block below.
COMMON_TASKS="apiDump --continue -Dlint.baselines.continue=true"
export GRADLE_OPTS="${GRADLE_OPTS} -Dorg.gradle.logging.stacktrace=all"
export GRADLE_OPTS="${GRADLE_OPTS} -Dorg.gradle.caching=false -Dkotlin.incremental=false"
export CI=true
export RELEASE=true
EXIT_CODE=0

echo ""
echo "===================================="
echo "======== RUN BASELINE TASKS ========"
echo "===================================="

# Force re-run for all the tasks
# -U: Refresh dependencies
#COMMON_TASKS="${COMMON_TASKS} --rerun-tasks -U"

# Root plugin module — has dependencyGuardBaseline. `detekt`-baseline
# and Android-lint-baseline tasks DO NOT exist in this build (pure
# JVM-Kotlin plugin, no `detekt --baseline` task wiring, no AGP). Do
# not reintroduce `detektBaselineMerge` / `updateLintBaseline` unless
# the underlying plugins are wired in (and then update this comment).
./gradlew ${COMMON_TASKS} dependencyGuardBaseline || EXIT_CODE=101

echo ""
echo "=======> checks/latest"
cd checks/latest || exit 102
pwd
# Latest cell has `dependency-guard` applied (matrix-top baseline)
# plus KMP `kotlinUpgradeYarnLock` for js/wasmJs.
./gradlew ${COMMON_TASKS} dependencyGuardBaseline kotlinUpgradeYarnLock || EXIT_CODE=103

echo ""
echo "=======> checks/middle"
cd ../middle || exit 107
pwd
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=108

echo ""
echo "=======> checks/kgp-only"
cd ../kgp-only || exit 109
pwd
# Embedded-only path. Also refresh KGP's KLIB ABI baseline via
# updateKotlinAbi — distinct from this plugin's apiDump.
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock updateKotlinAbi || EXIT_CODE=110

echo ""
echo "=======> checks/dual"
cd ../dual || exit 111
pwd
./gradlew ${COMMON_TASKS} kotlinUpgradeYarnLock || EXIT_CODE=112

echo ""
echo "=======> checks/js-only"
cd ../js-only || exit 104
pwd
# js-only uses the legacy `kotlin("js")` plugin (NOT KMP). The KMP
# `kotlinUpgradeYarnLock` task does NOT exist here; the legacy plugin
# exposes only `kotlinStoreYarnLock` / `kotlinRestoreYarnLock`. Storing
# (= overwriting the committed `kotlin-js-store/yarn.lock` from the
# current resolved state) is the legacy-equivalent of the KMP upgrade
# task; using it keeps the lock fresh against Kotlin bumps.
# js-only also has `dependency-guard` applied (floor-cell baseline).
./gradlew ${COMMON_TASKS} dependencyGuardBaseline kotlinStoreYarnLock || EXIT_CODE=105


# Go back to root
cd ../../ || exit 106

if [ ${EXIT_CODE} -ne 0 ]; then
  echo ""
  echo "================================"
  echo "== BASELINE TASKS FAILED: ${EXIT_CODE} =="
  echo "================================"
  exit ${EXIT_CODE}
fi
